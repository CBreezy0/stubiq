# Root environment reference for the open-source repository.
# Copy backend entries into backend/.env
# Copy frontend entries into frontend/.env.local

# Backend
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
JWT_SECRET=replace-with-a-long-random-secret
# Backend currently reads JWT_SECRET_KEY and JWT_REFRESH_SECRET_KEY.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-frontend-domain.com
JWT_SECRET_KEY=replace-with-a-long-random-32-byte-secret
JWT_REFRESH_SECRET_KEY=replace-with-a-second-long-random-32-byte-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
XBOX_CLIENT_ID=
XBOX_CLIENT_SECRET=
PLAYSTATION_CLIENT_ID=
PLAYSTATION_CLIENT_SECRET=
ENABLE_MOCK_CONSOLE_CONNECTIONS=true
AUTH_RATE_LIMIT_MAX_REQUESTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# Frontend
NEXT_PUBLIC_API_BASE_URL=https://stubiq-production.up.railway.app
